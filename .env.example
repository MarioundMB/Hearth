# Hearth – Konfigurationsvorlage
# Kopiere diese Datei nach .env und passe die Werte an.
# Der Install-Skript erstellt .env automatisch.

# Port, auf dem Hearth läuft
PORT=4500

# Verzeichnis, das der Dateimanager verwaltet (Host-Pfad)
DATA_DIR=/srv/hearth-data

# Zufälliger String für sichere Sessions – NIEMALS teilen oder leer lassen!
# Generieren: openssl rand -hex 32
SESSION_SECRET=ersetze-mich-durch-langen-zufallsstring

# Optional: Admin-Zugangsdaten direkt setzen (überspringt den Setup-Wizard)
# Wenn nicht gesetzt, startet der Wizard beim ersten Aufruf.
# ADMIN_USER=admin
# ADMIN_PASSWORD=meinSicheresPasswort
