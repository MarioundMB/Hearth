# Hearth – Configuration Template
# Copy this file to .env and adjust the values.
# The install script creates .env automatically.

# ── Ports ────────────────────────────────────────────────────────────────
# Hearth runs in host network mode (like hearth-firewall), so these ports
# are bound directly on the host — there is no Docker port mapping to adjust.

# Admin panel (keep behind firewall / VPN — do NOT expose publicly)
PORT=4500

# Guest view (safe to expose publicly — admin routes are blocked)
GUEST_PORT=3000

# Reverse proxy — HTTP port (Nginx built-in). Used for ACME challenges and
# redirecting to HTTPS. Must stay reachable on 80 from the internet if you
# want Let's Encrypt HTTP-01 verification to work.
HTTP_PORT=80

# Reverse proxy — HTTPS port (Nginx built-in). This is where your proxied
# domains are actually served with TLS.
PROXY_PORT=443

# ── Data ─────────────────────────────────────────────────────────────────
# Host path managed by the file manager
DATA_DIR=/srv/hearth-data

# File manager root inside the container. Defaults to /mnt (i.e. DATA_DIR
# only). Set to /host to give the file manager full read-write access to
# the entire host filesystem — same as a native panel like CasaOS. Only
# do this if you understand the risk: it can read/write/delete ANY file
# on the host through the web UI, including other apps' data and system
# files. Path traversal outside FILES_ROOT is still blocked either way.
# FILES_ROOT=/host

# ── Security ──────────────────────────────────────────────────────────────
# Random string for secure sessions — NEVER share or leave empty!
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Admin credentials (optional) — if not set, the setup wizard runs on first visit.
# ADMIN_USER=admin
# ADMIN_PASSWORD=mySecurePassword

# ── VPN (WireGuard) ───────────────────────────────────────────────────────
# Your server's public IP address or domain name
# VPN_HOST=your.server.com

# WireGuard UDP port (must be open in your firewall/router)
# VPN_PORT=51820

# Number of VPN client configs to generate automatically
# VPN_PEERS=3

# Timezone (used by WireGuard container)
# TZ=Europe/Berlin
