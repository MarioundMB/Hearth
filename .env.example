# Hearth – Configuration Template
# Copy this file to .env and adjust the values.
# The install script creates .env automatically.

# Port for the web interface
PORT=4500

# Host path managed by the file manager
DATA_DIR=/srv/hearth-data

# Random string for secure sessions — NEVER share or leave empty!
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Admin credentials (optional) — if not set, the setup wizard runs on first visit.
# ADMIN_USER=admin
# ADMIN_PASSWORD=mySecurePassword
